
// Example of Abstraction in Java
// An abstract class defines abstract methods (no implementation)
// Subclasses provide concrete implementations.

abstract class Animal {
	private String name;

	public Animal(String name) {
		this.name = name;
	}

	// Abstract method: subclasses must implement
	public abstract void makeSound();

	// Concrete method: shared behavior
	public void sleep() {
		System.out.println(name + " is sleeping.");
	}
}

class Dog extends Animal {
	public Dog(String name) {
		super(name);
	}

	@Override
	public void makeSound() {
		System.out.println("Woof!");
	}
}

public class TestAbstraction {
	public static void main(String[] args) {
		Animal a = new Dog("Buddy"); // use abstraction: reference type is abstract
		a.makeSound(); // calls Dog implementation
		a.sleep();
	}
}
